&usbdp_phy0 {
	mode-switch;
	orientation-switch;
	sbu1-dc-gpios = <&gpio1 RK_PB0 GPIO_ACTIVE_HIGH>;
	sbu2-dc-gpios = <&gpio1 RK_PA6 GPIO_ACTIVE_HIGH>;
	status = "okay";
	
	port {
		#address-cells = <1>;
		#size-cells = <0>;
		
		usbdp_phy0_ss: endpoint@0 {
			reg = <0>;
			remote-endpoint = <&usbc0_ss>;
		};
		
		usbdp_phy0_sbu: endpoint@1 {
			reg = <1>;
			remote-endpoint = <&usbc0_sbu>;
		};
	};
};

&usb_host0_xhci {
	usb-role-switch;
	status = "okay";
	
	port {
		usb_host0_xhci_to_usbc0: endpoint {
			remote-endpoint = <&usbc0_hs>;
		};
	};
};

