+static struct rk_pq_csc_coef create_rgb_gain_matrix(s32 r_gain, s32 g_gain, s32 b_gain)
+{
+	struct rk_pq_csc_coef m;
+
+	m.csc_coef00 = r_gain;
+	m.csc_coef01 = 0;
+	m.csc_coef02 = 0;
+
+	m.csc_coef10 = 0;
+	m.csc_coef11 = g_gain;
+	m.csc_coef12 = 0;
+
+	m.csc_coef20 = 0;
+	m.csc_coef21 = 0;
+	m.csc_coef22 = b_gain;
+
+	return m;
+}
