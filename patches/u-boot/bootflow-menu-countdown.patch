+int bootflow_menu_set_autoboot(struct expo *exp, int delay)
+{
+	struct menu_priv *priv = exp->priv;
+	struct abuf *buf;
+	struct scene *scn;
+	int ret;
+
+	scn = expo_lookup_scene_id(exp, MAIN);
+	if (!scn)
+		return log_msg_ret("scn", -ENOENT);
+
+	ret = scene_obj_set_hide(scn, OBJ_AUTOBOOT, delay < 0);
+	if (ret)
+		return log_msg_ret("hid", ret);
+	if (delay < 0)
+		return 0;
+
+	if (!priv->autoboot_buf) {
+		ret = expo_edit_str(exp, STR_AUTOBOOT, NULL, &buf);
+		if (ret)
+			return log_msg_ret("edt", ret);
+		priv->autoboot_buf = buf;
+	}
+
+	ret = abuf_printf(priv->autoboot_buf,
+			  "The highlighted entry will be executed automatically in %ds.",
+			  delay);
+	if (ret < 0)
+		return log_msg_ret("fmt", ret);
+
+	return 0;
+}
