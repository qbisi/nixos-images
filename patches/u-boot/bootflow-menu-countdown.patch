  *
  * @std: bootstd information
  * @text_mode: true to run the menu in text mode
+ * @delay: Delay in seconds before autoboot, or -1 to disable autoboot
  * @bflowp: Returns selected bootflow, on success
  * Return: 0 on success (a bootflow was selected), -EAGAIN if nothing was
  *	chosen, other -ve value on other error
  */
 __maybe_unused static int bootflow_handle_menu(struct bootstd_priv *std,
 					       bool text_mode,
+					       int delay,
 					       struct bootflow **bflowp)
 {
 	struct expo *exp;
 	struct bootflow *bflow;
+	ulong last_time = 0;
 	int ret, seq;
 
 	ret = bootflow_menu_start(std, text_mode, &exp);
 	if (ret)
 		return log_msg_ret("bhs", ret);
 
+	if (delay >= 0) {
+		last_time = get_timer(0);
+		ret = bootflow_menu_set_autoboot(exp, delay);
+		if (ret)
+			goto err_destroy;
+	} else {
+		ret = bootflow_menu_set_autoboot(exp, BOOTFLOW_MENU_DELAY_NONE);
+		if (ret)
+			goto err_destroy;
+	}
+
 	ret = -ERESTART;
 	do {
 		if (ret == -ERESTART) {
 			ret = expo_render(exp);
 			if (ret)
-				return log_msg_ret("bhr", ret);
+				goto err_destroy;
 		}
 		ret = bootflow_menu_poll(exp, &seq);
+		if (ret == -EAGAIN && !delay) {
+			ret = 0;
+		} else if (ret == -EAGAIN && delay > 0 &&
+			   get_timer(last_time) >= 1000) {
+			last_time = get_timer(0);
+			delay--;
+			ret = bootflow_menu_set_autoboot(exp, delay);
+			if (ret)
+				goto err_destroy;
+			if (!delay)
+				ret = 0;
+			else
+				ret = -ERESTART;
+		} else if (ret == -ERESTART && delay >= 0) {
+			delay = BOOTFLOW_MENU_DELAY_NONE;
+			ret = bootflow_menu_set_autoboot(exp, delay);
+			if (ret)
+				goto err_destroy;
+			ret = -ERESTART;
+		}
 	} while (ret == -EAGAIN || ret == -ERESTART);
 
 	if (ret == -EPIPE) {
@@ -130,6 +168,9 @@ __maybe_unused static int bootflow_handle_menu(struct bootstd_priv *std,
 		std->cur_bootflow = NULL;
 	} else if (ret) {
