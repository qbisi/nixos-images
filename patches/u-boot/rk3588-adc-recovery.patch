diff --git a/arch/arm/mach-rockchip/rk3588/boot_mode.c b/arch/arm/mach-rockchip/rk3588/boot_mode.c
new file mode 100644
index 00000000000..e2c3ee0234a
--- /dev/null
+++ b/arch/arm/mach-rockchip/rk3588/boot_mode.c
@@ -0,0 +1,23 @@
+#include <adc.h>
+#include <asm/global_data.h>
+
+#if CONFIG_IS_ENABLED(ADC)
+#define KEY_DOWN_MIN_VAL	0
+#define KEY_DOWN_MAX_VAL	100
+
+int rockchip_dnl_key_pressed(void)
+{
+
+	unsigned int val;
+
+	if (adc_channel_single_shot("adc@fec10000", 1, &val)) {
+		printf("%s read adc key val failed\n", __func__);
+		return false;
+	}
+
+	if (val >= KEY_DOWN_MIN_VAL && val <= KEY_DOWN_MAX_VAL)
+		return true;
+	else
+		return false;
+}
+#endif
