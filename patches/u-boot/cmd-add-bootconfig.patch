diff --git a/cmd/bootconfig.c b/cmd/bootconfig.c
new file mode 100644
index 00000000000..3f50ea45789
--- /dev/null
+++ b/cmd/bootconfig.c
@@ -0,0 +1,304 @@
+#include <charset.h>
+#include <cli.h>
+#include <command.h>
+#include <ansi.h>
+#include <env.h>
+#include <log.h>
+#include <menu.h>
+#include <malloc.h>
+#include <linux/string.h>
+#include <linux/delay.h>
+#include <vsprintf.h>
+
+#define MAX_TARGETS 16
+
+struct bootconfig_target {
+	char name[32];
+	bool active;
+};
+
+struct bootconfig_data;
+
+struct bootconfig_entry {
+	int index;
+	struct bootconfig_data *menu;
+};
+
+struct bootconfig_data {
+	struct bootconfig_target targets[MAX_TARGETS];
+	char keys[MAX_TARGETS + 2][4];
+	struct bootconfig_entry entries[MAX_TARGETS + 2];
+	int count;
+	int active;
+	int last_active;
+};
+
+static bool bootconfig_need_reprint(void *data)
+{
+	struct bootconfig_data *menu_data = data;
+	bool need_reprint;
+
+	need_reprint = (menu_data->last_active != menu_data->active);
+	menu_data->last_active = menu_data->active;
+
+	return need_reprint;
+}
+
+static void bootconfig_print_entry(void *data)
+{
+	struct bootconfig_entry *entry = data;
+	struct bootconfig_data *menu_data = entry->menu;
+	int i = entry->index;
+	bool reverse = (i == menu_data->active);
+
+	if (i == 0) {
+		printf(ANSI_CURSOR_POSITION, 4, 7);
+		puts("Current Boot Order:");
+	}
+
+	printf(ANSI_CURSOR_POSITION, i + 6, 7);
+	if (reverse)
+		puts(ANSI_COLOR_REVERSE);
+
+	if (i < menu_data->count) {
+		if (menu_data->targets[i].active)
+			printf("[*]  ");
+		else
+			printf("[ ]  ");
+
+		printf("%s", menu_data->targets[i].name);
+	} else if (i == menu_data->count) {
+		printf("Save and Exit");
+	} else if (i == menu_data->count + 1) {
+		printf("Quit");
+	}
+
+	/* Clear trailing characters from previous print */
+	puts(ANSI_CLEAR_LINE_TO_END);
+
+	if (reverse)
+		puts(ANSI_COLOR_RESET);
+}
+
+static void bootconfig_display_statusline(struct menu *m)
+{
+	printf(ANSI_CURSOR_POSITION, 1, 1);
+	puts(ANSI_CLEAR_LINE);
+	printf(ANSI_CURSOR_POSITION, 2, 3);
+	puts("*** U-Boot Boot Configuration ***");
+	puts(ANSI_CLEAR_LINE_TO_END);
+	printf(ANSI_CURSOR_POSITION, 3, 1);
+	puts(ANSI_CLEAR_LINE);
+
+	printf(ANSI_CURSOR_POSITION, 24, 3);
+	puts("UP/DOWN: move | +/-: sort | SPACE: enable/disable | ENTER: select | ESC: quit");
+	puts(ANSI_CLEAR_LINE_TO_END);
+}
+
+static char *bootconfig_choice_entry(void *data)
+{
+	struct cli_ch_state s_cch, *cch = &s_cch;
+	struct bootconfig_data *menu_data = data;
+	enum bootmenu_key key;
+
+	cli_ch_init(cch);
+
+	while (1) {
+		key = bootmenu_loop(NULL, cch);
+
+		switch (key) {
+		case BKEY_UP:
+			if (menu_data->active > 0) {
+				menu_data->active--;
+				return NULL;
+			}
+			break;
+		case BKEY_DOWN:
+			if (menu_data->active < menu_data->count + 1) {
+				menu_data->active++;
+				return NULL;
+			}
+			break;
+		case BKEY_PLUS:
+			if (menu_data->active > 0 && menu_data->active < menu_data->count) {
+				struct bootconfig_target tmp = menu_data->targets[menu_data->active];
+				menu_data->targets[menu_data->active] = menu_data->targets[menu_data->active - 1];
+				menu_data->targets[menu_data->active - 1] = tmp;
+				menu_data->active--;
+				menu_data->last_active = -1; /* force redraw */
+				return NULL;
+			}
+			break;
+		case BKEY_MINUS:
+			if (menu_data->active < menu_data->count - 1) {
+				struct bootconfig_target tmp = menu_data->targets[menu_data->active];
+				menu_data->targets[menu_data->active] = menu_data->targets[menu_data->active + 1];
+				menu_data->targets[menu_data->active + 1] = tmp;
+				menu_data->active++;
+				menu_data->last_active = -1; /* force redraw */
+				return NULL;
+			}
+			break;
+		case BKEY_SPACE:
+			if (menu_data->active < menu_data->count) {
+				menu_data->targets[menu_data->active].active = !menu_data->targets[menu_data->active].active;
+				menu_data->last_active = -1; /* force redraw */
+				return NULL;
+			}
+			break;
+		case BKEY_SELECT:
+			/* If "Save and Exit" or "Quit" is highlighted */
+			if (menu_data->active >= menu_data->count)
+				return menu_data->keys[menu_data->active];
+			break; /* Wait for valid input otherwise */
+		case BKEY_QUIT:
+			return menu_data->keys[menu_data->count + 1];
+		default:
+			break;
+		}
+	}
+	return NULL;
+}
+
+static int do_bootconfig(struct cmd_tbl *cmdtp, int flag, int argc, char *const argv[])
+{
+	struct bootconfig_data *data;
+	struct menu *m;
+	char *targets_backup_env;
+	char *targets_env;
+	char *tok;
+	char buf[512];
+	char buf_act[512];
+	void *choice = NULL;
+	int init = 0;
+	int sel;
+
+	data = calloc(1, sizeof(*data));
+	if (!data)
+		return CMD_RET_FAILURE;
+
+	data->last_active = -1;
+
+	targets_backup_env = env_get("boot_targets_all");
+	targets_env = env_get("boot_targets");
+
+	if (targets_backup_env) {
+		strncpy(buf, targets_backup_env, sizeof(buf) - 1);
+		buf[sizeof(buf) - 1] = '\0';
+		tok = strtok(buf, " ");
+		while (tok && data->count < MAX_TARGETS) {
+			strncpy(data->targets[data->count].name, tok, 31);
+			data->targets[data->count].active = false;
+			data->count++;
+			tok = strtok(NULL, " ");
+		}
+
+		if (targets_env) {
+			strncpy(buf_act, targets_env, sizeof(buf_act) - 1);
+			buf_act[sizeof(buf_act) - 1] = '\0';
+			tok = strtok(buf_act, " ");
+			while (tok) {
+				for (int i = 0; i < data->count; i++) {
+					if (!strcmp(data->targets[i].name, tok)) {
+						data->targets[i].active = true;
+						break;
+					}
+				}
+				tok = strtok(NULL, " ");
+			}
+		}
+	} else if (targets_env) {
+		strncpy(buf, targets_env, sizeof(buf) - 1);
+		buf[sizeof(buf) - 1] = '\0';
+		tok = strtok(buf, " ");
+		while (tok && data->count < MAX_TARGETS) {
+			strncpy(data->targets[data->count].name, tok, 31);
+			data->targets[data->count].active = true;
+			data->count++;
+			tok = strtok(NULL, " ");
+		}
+	} else {
+		// Default fallback
+		strcpy(data->targets[0].name, "mmc0");
+		strcpy(data->targets[1].name, "mmc1");
+		strcpy(data->targets[2].name, "usb0");
+		strcpy(data->targets[3].name, "pxe");
+		strcpy(data->targets[4].name, "dhcp");
+		for (int i = 0; i < 5; i++)
+			data->targets[i].active = true;
+		data->count = 5;
+	}
+
+	m = menu_create(NULL, 0, 1, bootconfig_display_statusline,
+			bootconfig_print_entry, bootconfig_choice_entry,
+			bootconfig_need_reprint, data);
+	if (!m) {
+		free(data);
+		return CMD_RET_FAILURE;
+	}
+
+	/* Add menu items: count targets + 1 (Save) + 1 (Quit) */
+	for (int i = 0; i <= data->count + 1; i++) {
+		sprintf(data->keys[i], "%d", i);
+		data->entries[i].index = i;
+		data->entries[i].menu = data;
+		if (menu_item_add(m, data->keys[i], &data->entries[i]) != 1) {
+			menu_destroy(m);
+			free(data);
+			return CMD_RET_FAILURE;
+		}
+	}
+	menu_default_set(m, "0");
+
+	puts(ANSI_CURSOR_HIDE);
+	puts(ANSI_CLEAR_CONSOLE);
+	printf(ANSI_CURSOR_POSITION, 1, 1);
+	init = 1;
+
+	if (menu_get_choice(m, &choice) == 1) {
+		struct bootconfig_entry *entry = choice;
+		sel = entry->index;
+
+		if (sel == data->count) {
+			// Save and Exit
+			buf[0] = '\0';
+			buf_act[0] = '\0';
+			for (int i = 0; i < data->count; i++) {
+				strncat(buf, data->targets[i].name, sizeof(buf) - strlen(buf) - 1);
+				strncat(buf, " ", sizeof(buf) - strlen(buf) - 1);
+
+				if (data->targets[i].active) {
+					strncat(buf_act, data->targets[i].name, sizeof(buf_act) - strlen(buf_act) - 1);
+					strncat(buf_act, " ", sizeof(buf_act) - strlen(buf_act) - 1);
+				}
+			}
+			/* Remove trailing space */
+			if (strlen(buf) > 0)
+				buf[strlen(buf) - 1] = '\0';
+			if (strlen(buf_act) > 0)
+				buf_act[strlen(buf_act) - 1] = '\0';
+
+			env_set("boot_targets_all", buf);
+			env_set("boot_targets", buf_act);
+			env_save();
+		}
+		/* If sel == data->count + 1, it's "Quit", do nothing */
+	}
+
+	if (init) {
+		puts(ANSI_CURSOR_SHOW);
+		puts(ANSI_CLEAR_CONSOLE);
+		printf(ANSI_CURSOR_POSITION, 1, 1);
+	}
+
+	menu_destroy(m);
+	free(data);
+
+	return CMD_RET_SUCCESS;
+}
+
+U_BOOT_CMD(
+	bootconfig, 1, 0, do_bootconfig,
+	"Boot configuration menu",
+	"Provides a menu to edit boot_targets"
+);
